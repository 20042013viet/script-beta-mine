-- [LOGIC CODE FARM]
----------------------------------------------------------------
local function getMonster()
    for _, v in ipairs(workspace.Enemies:GetChildren()) do
        if v.Name == "Bandit" and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
            return v
        end
    end
    for _, v in ipairs(workspace:GetChildren()) do
        if v.Name == "Bandit" and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
            return v
        end
    end
    return nil
end

local function hasQuest()
    local mainGui = plr.PlayerGui:FindFirstChild("Main")
    local questFrame = mainGui and mainGui:FindFirstChild("Quest")
    return questFrame and questFrame.Visible == true
end

local function fastAttack(monster)
    local character = plr.Character
    local tool = character and character:FindFirstChildOfClass("Tool")
    
    if tool and monster and monster:FindFirstChild("HumanoidRootPart") then
        VirtualUser:CaptureController()
        VirtualUser:ClickButton1(Vector2.new(850, 520))
        
        local combatRemote = ReplicatedStorage:FindFirstChild("RigControllerCombat") or ReplicatedStorage:WaitForChild("Remotes"):FindFirstChild("Validator")
        if combatRemote then
            combatRemote:FireServer(monster.HumanoidRootPart.Position)
        end
    end
end

-- Vòng lặp chính điều khiển toàn bộ logic thông minh
task.spawn(function()
    while task.wait(0.1) do
        if _G.AutoFarm then
            -- Luôn kiểm tra tiền để mua Melee trước
            autoBuyMelee()
            
            -- ƯU TIÊN 1: Kiểm tra xem trên map có Trái Ác Quỷ nào không
            local targetFruit = getFruit()
            if targetFruit and targetFruit:FindFirstChild("Handle") then
                StatusLabel.Text = "Phát hiện Trái Ác Quỷ! Đang bay tới nhặt..."
                _G.TargetCFrame = targetFruit.Handle.CFrame
                
                -- Đợi nhặt lên tay rồi tự động lưu trữ
                task.wait(0.5)
                storeFruit()
            else
                -- ƯU TIÊN 2: Nếu không có Trái Ác Quỷ thì tiếp tục farm quái bình thường
                if not hasQuest() then
                    _G.TargetCFrame = NpcCFrame
                    CommF:InvokeServer("StartQuest", "BanditQuest", 1)
                else
                    local targetMonster = getMonster()
                    if targetMonster then
                        StatusLabel.Text = "Auto Farm: Level [Bandit]"
                        _G.TargetCFrame = targetMonster.HumanoidRootPart.CFrame * CFrame.new(0, 20, 0) * CFrame.Angles(math.rad(-90), 0, 0)
                        fastAttack(targetMonster)
                    else
                        _G.TargetCFrame = NpcCFrame
                    end
                end
            end
        end
    end
end)

-- Vòng lặp xử lý di chuyển Bay (Fly) kết hợp Xuyên Tường (NoClip)
RunService.Stepped:Connect(function()
    if _G.AutoFarm then
        local character = plr.Character
        if character then
            for _, child in ipairs(character:GetChildren()) do
                if child:IsA("BasePart") then
                    child.CanCollide = false
                end
            end
        end
        
        if _G.TargetCFrame then
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            
            if rootPart and humanoid and humanoid.Health > 0 then
                rootPart.Velocity = Vector3.new(0, 0, 0)
                rootPart.CFrame = _G.TargetCFrame
            end
        end
    end
end)
