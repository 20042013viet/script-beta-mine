-- ĐẤM SIÊU TỐC CHỐNG HOẠT ẢNH THỪA (FAST ATTACK)
local function hitMonster()
    VirtualUser:CaptureController()
    VirtualUser:ClickButton1(Vector2.new(50, 50))
    
    -- Gửi thêm packet tấn công phụ để kích tốc độ đánh lên tối đa
    local combatRemote = ReplicatedStorage:FindFirstChild("RigControllerCombat") or ReplicatedStorage:WaitForChild("Remotes"):FindFirstChild("Validator")
    if combatRemote then
        combatRemote:FireServer("LeftClick")
    end
end

local function equipMeleeWeapon()
    local backpack = plr.Backpack
    local character = plr.Character
    if character then
        local currentTool = character:FindFirstChildOfClass("Tool")
        if currentTool and currentTool.ToolTip == "Melee" then
            return 
        end
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and tool.ToolTip == "Melee" then
                tool.Parent = character
                break
            end
        end
    end
end

local function processFruits()
    for _, v in ipairs(workspace:GetChildren()) do
        if v:IsA("Tool") and string.find(v.Name, "Fruit") then
            if v:FindFirstChild("Handle") then
                _G.TargetCFrame = v.Handle.CFrame
                task.wait(0.3)
                if v.Parent == plr.Character and v:FindFirstChild("DataId") then
                    CommF:InvokeServer("StoreFruit", v.DataId.Value, v)
                end
                return true
            end
        end
    end
    return false
end

local function getMonster()
    for _, v in ipairs(workspace.Enemies:GetChildren()) do
        if v.Name == "Bandit" and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
            return v
        end
    end
    for _, v in ipairs(workspace:GetChildren()) do
        if v.Name == "Bandit" and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
            return v
        end
    end
    return nil
end

-- CƠ CHẾ GOM QUÁI TỰ ĐỘNG (BRING MOBS)
local function bringMonsters(targetMonster)
    if not targetMonster or not targetMonster:FindFirstChild("HumanoidRootPart") then return end
    local targetCFrame = targetMonster.HumanoidRootPart.CFrame

    for _, v in ipairs(workspace.Enemies:GetChildren()) do
        if v.Name == "Bandit" and v:FindFirstChild("HumanoidRootPart") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
            if v ~= targetMonster then
                -- Hút toàn bộ quái phụ về vị trí của con quái chính
                v.HumanoidRootPart.CanCollide = false
                v.HumanoidRootPart.CFrame = targetCFrame
                v.Humanoid:ChangeState(Enum.HumanoidStateType.RunningNoPhysics)
            end
        end
    end
end

local function hasQuest()
    local mainGui = plr.PlayerGui:FindFirstChild("Main")
    if mainGui and mainGui:FindFirstChild("Quest") and mainGui.Quest.Visible == true then
        local container = mainGui.Quest:FindFirstChild("Container")
        if container and container:FindFirstChild("QuestTitle") and string.find(container.QuestTitle.Text, "Bandit") then
            return true
        end
    end
    return false
end

-- VÒNG LẶP ĐIỀU KHIỂN CHÍNH
task.spawn(function()
    while task.wait(0.01) do -- Giảm delay xuống mức tối thiểu để farm quái tức thì
        if _G.AutoFarm then
            joinPirates() 
            
            local holdingFruit = processFruits()
            
            if not holdingFruit then
                if not hasQuest() then
                    _G.TargetCFrame = NpcCFrame
                    task.wait(0.2)
                    CommF:InvokeServer("StartQuest", "BanditQuest", 1)
                else
                    local targetMonster = getMonster()
                    if targetMonster then
                        -- Bay sát đầu quái 3 block để nắm đấm Melee chạm đích
                        _G.TargetCFrame = targetMonster.HumanoidRootPart.CFrame * CFrame.new(0, 3, 0) * CFrame.Angles(math.rad(-90), 0, 0)
                        
                        bringMonsters(targetMonster) -- Gọi hàm gom quái liên tục
                        equipMeleeWeapon() 
                        hitMonster()       
                    else
                        _G.TargetCFrame = NpcCFrame
                    end
                end
            end
        end
    end
end)

-- VÒNG LẶP XỬ LÝ KHÓA VỊ TRÍ (FLY) VÀ XUYÊN TƯỜNG (NOCLIP)
RunService.Stepped:Connect(function()
    if _G.AutoFarm then
        local character = plr.Character
        if character then
            for _, child in ipairs(character:GetChildren()) do
                if child:IsA("BasePart") then
                    child.CanCollide = false
                end
            end
            if _G.TargetCFrame then
                local rootPart = character:FindFirstChild("HumanoidRootPart")
                local humanoid = character:FindFirstChildOfClass("Humanoid")
                if rootPart and humanoid and humanoid.Health > 0 then
                    rootPart.Velocity = Vector3.new(0, 0, 0)
                    rootPart.CFrame = _G.TargetCFrame
                end
            end
        end
    end
end)
