-- 1. Tìm Trái Ác Quỷ rơi rớt trên map
local function getFruit()
    for _, v in ipairs(workspace:GetChildren()) do
        if v:IsA("Tool") and (string.find(v.Name, "Fruit") or string.find(v.Name, "Trái")) then
            return v
        end
    end
    return nil
end

-- 2. Tự động cất trái ác quỷ vào rương lưu trữ
local function storeFruit()
    local character = plr.Character
    if character then
        local fruit = character:FindFirstChildOfClass("Tool")
        if fruit and (string.find(fruit.Name, "Fruit") or string.find(fruit.Name, "Trái")) then
            -- Gọi lệnh cất trái vào kho lưu trữ từ xa
            CommF:InvokeServer("StoreFruit", fruit.Name, fruit)
        end
    end
end

-- 3. Tự động mua võ chân (Dark Step) khi đủ tiền
local hasBoughtDarkStep = false
local function autoBuyMelee()
    if not hasBoughtDarkStep and plr.Data.Beli.Value >= 150000 then
        -- Gửi tín hiệu mua võ chân từ xa tới NPC Black Leg Teacher
        local buyResult = CommF:InvokeServer("BuyBlackLeg")
        if buyResult then
            hasBoughtDarkStep = true
            StatusLabel.Text = "Hệ thống: Đã tự động mua Chân Hắc Cước!"
        end
    end
end

