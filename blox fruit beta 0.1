-- Gửi lệnh chém liên tục từ xa
local function hitMonster()
    local combatRemote = ReplicatedStorage:FindFirstChild("RigControllerCombat") or ReplicatedStorage:WaitForChild("Remotes"):FindFirstChild("Validator")
    if combatRemote then
        combatRemote:FireServer("LeftClick")
    end
end

-- CƠ CHẾ THÔNG MINH: TỰ ĐỘNG SỬ DỤNG VÕ (MELEE) ĐỂ ĐÁNH QUÁI
local function equipMeleeWeapon()
    local backpack = plr.Backpack
    local character = plr.Character
    
    if character then
        -- Bước 1: Kiểm tra xem trên tay đã cầm sẵn võ (Melee) chưa
        local currentTool = character:FindFirstChildOfClass("Tool")
        if currentTool and currentTool.ToolTip == "Melee" then
            return -- Đang cầm võ rồi thì không cần làm gì thêm
        end
        
        -- Bước 2: Nếu chưa cầm hoặc đang cầm vũ khí khác, tìm võ (Melee) trong túi đồ
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and tool.ToolTip == "Melee" then
                tool.Parent = character -- Đeo võ lên tay
                break
            end
        end
    end
end

-- Tự động kiểm tra và nhặt + lưu trữ trái ác quỷ gốc
local function processFruits()
    for _, v in ipairs(workspace:GetChildren()) do
        if v:IsA("Tool") and string.find(v.Name, "Fruit") then
            if v:FindFirstChild("Handle") then
                _G.TargetCFrame = v.Handle.CFrame
                task.wait(0.3)
                if v.Parent == plr.Character and v:FindFirstChild("DataId") then
                    CommF:InvokeServer("StoreFruit", v.DataId.Value, v)
                end
                return true
            end
        end
    end
    return false
end

-- Tự động mua võ chân (Dark Step) khi có đủ 150k Beli
local hasBoughtDarkStep = false
local function autoBuyMelee()
    if not hasBoughtDarkStep and plr.Data.Beli.Value >= 150000 then
        local buyResult = CommF:InvokeServer("BuyBlackLeg")
        if buyResult then hasBoughtDarkStep = true end
    end
end

-- Tìm quái Bandit
local function getMonster()
    for _, v in ipairs(workspace.Enemies:GetChildren()) do
        if v.Name == "Bandit" and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
            return v
        end
    end
    for _, v in ipairs(workspace:GetChildren()) do
        if v.Name == "Bandit" and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
            return v
        end
    end
    return nil
end

local function hasQuest()
    local mainGui = plr.PlayerGui:FindFirstChild("Main")
    local questFrame = mainGui and mainGui:FindFirstChild("Quest")
    return questFrame and questFrame.Visible == true
end

-- VÒNG LẶP CHÍNH ĐIỀU KHIỂN TOÀN BỘ LOGIC
task.spawn(function()
    while task.wait(0.1) do
        if _G.AutoFarm then
            joinPirates() 
            autoBuyMelee() 
            
            -- Ưu tiên xử lý trái ác quỷ trước
            local holdingFruit = processFruits()
            
            if not holdingFruit then
                -- Nếu không có trái ác quỷ rơi thì chuyển qua farm quái
                if not hasQuest() then
                    _G.TargetCFrame = NpcCFrame
                    CommF:InvokeServer("StartQuest", "BanditQuest", 1)
                else
                    local targetMonster = getMonster()
                    if targetMonster then
                        -- Bay lên đầu quái tạo vùng an toàn (Safe Area)
                        _G.TargetCFrame = targetMonster.HumanoidRootPart.CFrame * CFrame.new(0, 22, 0) * CFrame.Angles(math.rad(-90), 0, 0)
                        
                        equipMeleeWeapon() -- Luôn gọi cơ chế tự động cầm Võ (Melee) lên tay
                        hitMonster()       -- Thực hiện đấm quái liên tục
                    else
                        _G.TargetCFrame = NpcCFrame
                    end
                end
            end
        end
    end
end)

-- VÒNG LẶP XỬ LÝ BAY (FLY) VÀ XUYÊN TƯỜNG (NOCLIP) TOÀN DIỆN
RunService.Stepped:Connect(function()
    if _G.AutoFarm then
        local character = plr.Character
        if character then
            for _, child in ipairs(character:GetChildren()) do
                if child:IsA("BasePart") then
                    child.CanCollide = false
                end
            end
            if _G.TargetCFrame then
                local rootPart = character:FindFirstChild("HumanoidRootPart")
                local humanoid = character:FindFirstChildOfClass("Humanoid")
                if rootPart and humanoid and humanoid.Health > 0 then
                    rootPart.Velocity = Vector3.new(0, 0, 0)
                    rootPart.CFrame = _G.TargetCFrame
                end
            end
        end
    end
end)
